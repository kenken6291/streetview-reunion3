# ============================================================
#  .gitignore — Gitの追跡から除外するファイル一覧
# ============================================================

# -------------------------------------------------------
# 【最重要】APIキーなど機密情報を含むファイル
# このファイルをGitHubに公開すると、APIキーが漏洩します！
# -------------------------------------------------------
config.js

# -------------------------------------------------------
# 環境変数ファイル（Node.js等で使う場合）
# -------------------------------------------------------
.env
.env.local
.env.*.local

# -------------------------------------------------------
# macOS のシステムファイル
# -------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -------------------------------------------------------
# Windows のシステムファイル
# -------------------------------------------------------
Thumbs.db
ehthumbs.db
desktop.ini

# -------------------------------------------------------
# エディタ・IDE の設定ファイル
# -------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------------------
# Node.js（将来的に使う場合）
# -------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------------------
# ビルド成果物（将来的に使う場合）
# -------------------------------------------------------
dist/
build/